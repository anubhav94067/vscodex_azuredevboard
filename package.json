{
  "name": "azure-devops-time-tracker",
  "displayName": "Azure DevOps Time Tracker",
  "description": "Track Azure DevOps work items and time spent on them directly in VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Azure DevOps Time Tracker",
      "properties": {
        "azure-devops-time-tracker.organization": {
          "type": "string",
          "default": "",
          "description": "Your Azure DevOps organization name."
        },
        "azure-devops-time-tracker.project": {
          "type": "string",
          "default": "",
          "description": "Your Azure DevOps project name."
        },
        "azure-devops-time-tracker.personalAccessToken": {
          "type": "string",
          "default": "",
          "description": "Your Azure DevOps Personal Access Token (PAT)."
        },
        "azure-devops-time-tracker.queryId": {
          "type": "string",
          "default": "",
          "description": "The ID of the Azure DevOps query to fetch work items."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "azureDevopsWorkItems",
          "name": "Azure DevOps",
          "icon": "$(list-flat)"
        }
      ]
    },
    "commands": [
      {
        "command": "azure-devops-time-tracker.configure",
        "title": "Configure Azure DevOps Settings"
      },
      {
        "command": "azure-devops-time-tracker.refreshWorkItems",
        "title": "Refresh Work Items",
        "icon": "$(refresh)"
      },
      {
        "command": "azure-devops-time-tracker.startTimer",
        "title": "Start Timer",
        "icon": "$(debug-start)"
      },
      {
        "command": "azure-devops-time-tracker.stopTimer",
        "title": "Stop Timer",
        "icon": "$(debug-stop)"
      },
      {
        "command": "azure-devops-time-tracker.openWorkItemInBrowser",
        "title": "Open in Browser"
      },
      {
        "command": "azure-devops-time-tracker.closeWorkItem",
        "title": "Close Work Item",
        "icon": "$(check)"
      },
      {
        "command": "azure-devops-time-tracker.showWorkItemsInView",
        "title": "Show Work Items in VS Code",
        "icon": "$(preview)"
      },
      {
        "command": "azure-devops-time-tracker.openWorkItemInView",
        "title": "Open Work Item in VS Code",
        "icon": "$(file-symlink-file)"
      }
    ],
    "menus": {
    "commandPalette": [
      {
        "command": "azure-devops-time-tracker.configure",
        "when": "true"
      },
      {
        "command": "azure-devops-time-tracker.showWorkItemsInView",
        "when": "true"
      }
    ],
    "view/title": [
      {
        "command": "azure-devops-time-tracker.refreshWorkItems",
        "when": "view == azureDevopsWorkItems",
        "group": "navigation"
      },
      {
        "command": "azure-devops-time-tracker.showWorkItemsInView",
        "when": "view == azureDevopsWorkItems",
        "group": "navigation@2"
      }
    ],
    "view/item/context": [
      {
        "command": "azure-devops-time-tracker.openWorkItemInBrowser",
        "when": "view == azureDevopsWorkItems && viewItem != message",
        "group": "navigation"
      },
      {
        "command": "azure-devops-time-tracker.openWorkItemInView",
        "when": "view == azureDevopsWorkItems && viewItem != message",
        "group": "navigation@2"
      },
      {
        "command": "azure-devops-time-tracker.startTimer",
        "when": "view == azureDevopsWorkItems && viewItem == workItem",
        "group": "inline"
      },
      {
        "command": "azure-devops-time-tracker.stopTimer",
        "when": "view == azureDevopsWorkItems && viewItem == workItem-active",
        "group": "inline"
      },
      {
        "command": "azure-devops-time-tracker.closeWorkItem",
        "when": "view == azureDevopsWorkItems && viewItem == workItem-completed",
        "group": "inline"
      }
    ]
		}
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.9",
    "eslint": "^9.34.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@types/axios": "^0.9.36",
    "axios": "^1.12.2"
  }
}
